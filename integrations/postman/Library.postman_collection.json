{
  "info": {
    "name": "Library API",
    "description": "Library Management System API collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Books",
      "item": [
        {
          "name": "Get All Books",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/books"
          }
        },
        {
          "name": "Get Book by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/books/{{bookId}}"
          }
        },
        {
          "name": "Get Available Books",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/books/available"
          }
        },
        {
          "name": "Create Book",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/books",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Clean Architecture\",\n  \"author\": \"Robert C. Martin\",\n  \"isbn\": \"978-0134494166\",\n  \"publishedYear\": 2017,\n  \"isAvailable\": true,\n  \"bookCategoryId\": null\n}"
            }
          }
        },
        {
          "name": "Update Book",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/books/{{bookId}}",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Clean Architecture (Updated)\",\n  \"author\": \"Robert C. Martin\",\n  \"isbn\": \"978-0134494166\",\n  \"publishedYear\": 2017,\n  \"isAvailable\": false,\n  \"bookCategoryId\": null\n}"
            }
          }
        },
        {
          "name": "Delete Book",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/books/{{bookId}}"
          }
        }
      ]
    },
